# Kopieren nach .env und ausfüllen:  cp .env.example .env
# Wird per `env_file` literal an die Container gereicht — daher KEINE
# Anführungszeichen und das '$' im Hash NICHT escapen.

# PFLICHT — Basic-Auth-Hash fürs Cockpit. Erzeugen mit:
#   docker run --rm caddy:2 caddy hash-password --plaintext 'DEIN_PASS'
# Beispiel (roh übernehmen):  CDD_PASS_HASH=$2a$14$abc...   ← kein "", kein $$
CDD_PASS_HASH=

# Auth + Domain
CDD_USER=cong
CDD_DOMAIN=localhost        # echte Domain (z. B. cdd.cong42.de) → Caddy holt Let's-Encrypt

# Ports (Defaults sind Standard 80/443; für lokalen Test ggf. >1024 wählen)
CDD_HTTP_PORT=80
CDD_HTTPS_PORT=443

# Optional — nur für die (experimentelle) Cockpit-Chat-Loop
ANTHROPIC_API_KEY=
OLLAMA_HOST=                # z. B. http://host.docker.internal:11434
